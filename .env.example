# Discord
DISCORD_TOKEN=your-bot-token
# Comma-separated guild IDs for instant command sync during dev.
# Leave blank in production to register commands globally.
DISCORD_GUILD_IDS=

# Database — supports postgres://, postgresql://, or postgresql+asyncpg:// forms.
DATABASE_URL=postgresql+asyncpg://pomodoro:pomodoro@localhost:5432/pomodoro

# Pomodoro cycle (seconds)
POMO_WORK_SECONDS=1500
POMO_SHORT_BREAK_SECONDS=300
POMO_LONG_BREAK_SECONDS=900
POMO_LONG_BREAK_EVERY=4

# Logging
LOG_LEVEL=INFO
