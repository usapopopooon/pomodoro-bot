# Local-only image for scripts/generate_voices.py. Used from
# docker-compose.gen.yml; never deployed with the bot.
FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

RUN pip install aiohttp

COPY scripts/ scripts/

ENTRYPOINT ["python", "scripts/generate_voices.py"]
